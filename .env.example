# Trello Clone — environment configuration
#
# This file documents the configurable environment variables.
# The Angular app reads `src/environments/environment.ts` at build time
# (Angular's fileReplacements swaps it for `environment.prod.ts` in
# production builds). For local development, edit environment.ts
# directly. For environment-specific configuration outside of build
# flavors, consider wiring an InjectionToken + provideAppConfig
# pattern that reads these values via a build-time replacement.

# Public API endpoint for the Trello backend
API_URL=https://fake-trello-api.herokuapp.com
