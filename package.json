{
  "name": "trello-auth",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "ng lint",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install chromium"
  },
  "private": true,
  "engines": {
    "node": ">=18.19.1"
  },
  "dependencies": {
    "@angular/cdk": "~22.0.2",
    "@angular/common": "~22.0.2",
    "@angular/compiler": "~22.0.2",
    "@angular/core": "~22.0.2",
    "@angular/forms": "~22.0.2",
    "@angular/platform-browser": "~22.0.2",
    "@angular/router": "~22.0.2",
    "@material-symbols/font-400": "^0.45.2",
    "rxjs": "~7.8.2"
  },
  "devDependencies": {
    "@angular-eslint/builder": "22.0.0",
    "@angular/build": "^22.0.3",
    "@angular/cli": "~22.0.3",
    "@angular/compiler-cli": "~22.0.2",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/forms": "~0.5.11",
    "@tailwindcss/postcss": "^4.3",
    "@testing-library/angular": "^19.4.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@vitest/coverage-v8": "^4.1.9",
    "angular-eslint": "^22.0.0",
    "eslint": "^10.5.0",
    "jsdom": "^29.1.1",
    "postcss": "~8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
